    <Compile Include="Views\TextOnly\Pages.fs" />
    <Compile Include="Views\Partials.fs" />
    <Compile Include="Views\Generator.fs" />
    <Compile Include="BuildDriver.fs" />
    <Compile Include="Collections.fs" />
    <Compile Include="SearchIndex.fs" />
    <Compile Include="Loaders.fs" />
    <Compile Include="TextOnlyBuilder.fs" />
    <Compile Include="Builders\Common.fs" />
    <Compile Include="Builders\Assets.fs" />
    <Compile Include="Builders\AiMemexPages.fs" />
    <Compile Include="Builders\ResumePage.fs" />
    <Compile Include="Builders\CollectionPages.fs" />
    <Compile Include="Builders\LegacyFeeds.fs" />
