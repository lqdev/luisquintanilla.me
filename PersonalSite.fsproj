<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RestorePackagesWithLockFile>true</RestorePackagesWithLockFile>
    <!-- F# incomplete pattern matches (FS0025) are build errors. This is the
         enforcement payoff for the closed ContentType DU (Phase 2.7): adding a
         case turns every non-exhaustive match into a compile error. Verified
         free at adoption (2026-06-10): build emitted 0 FS0025. -->
    <WarningsAsErrors>FS0025</WarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Domain.fs" />
    <Compile Include="ContentTypes.fs" />
    <Compile Include="CustomBlocks.fs" />
    <Compile Include="MediaTypes.fs" />
    <Compile Include="ASTParsing.fs" />
    <Compile Include="Diagnostics.fs" />
    <Compile Include="BlockRenderers.fs" />
    <Compile Include="OutputComparison.fs" />
    <Compile Include="Services\Markdown.fs" />
    <Compile Include="Services\Tag.fs" />
    <Compile Include="Services\ReadingTime.fs" />
    <Compile Include="Services\Opml.fs" />    
    <Compile Include="Services\Webmention.fs" />
    <Compile Include="Services\RelatedContent.fs" />
    <Compile Include="Services\FollowersSync.fs" /> 
    <Compile Include="Services\QRStyled.fs" />
    <Compile Include="GenericBuilder.fs" />
    <Compile Include="Processors\PostProcessor.fs" />
    <Compile Include="Processors\NoteProcessor.fs" />
    <Compile Include="Processors\SnippetProcessor.fs" />
    <Compile Include="Processors\WikiProcessor.fs" />
    <Compile Include="Processors\AiMemexProcessor.fs" />
    <Compile Include="Processors\PresentationProcessor.fs" />
    <Compile Include="Processors\ReviewDataExtractor.fs" />
    <Compile Include="Processors\MediaExtractor.fs" />
    <Compile Include="Processors\BookProcessor.fs" />
    <Compile Include="Processors\ResponseProcessor.fs" />
    <Compile Include="Processors\MediaDataExtractor.fs" />
    <Compile Include="Processors\AlbumProcessor.fs" />
    <Compile Include="Processors\AlbumCollectionProcessor.fs" />
    <Compile Include="Processors\PlaylistCollectionProcessor.fs" />
    <Compile Include="Processors\BookmarkProcessor.fs" />
    <Compile Include="Processors\MarketplaceProcessor.fs" />
    <Compile Include="UnifiedFeeds.fs" />
    <Compile Include="ContentRegistry.fs" />
    <Compile Include="ActivityPubBuilder.fs" />
    <Compile Include="EntityExtraction.fs" />
    <Compile Include="KnowledgeGraph.fs" />
    <Compile Include="RdfSerializer.fs" />
    <Compile Include="Views\ComponentViews.fs" />
    <Compile Include="Views\TagViews.fs" />
    <Compile Include="Views\FeedViews.fs" />
    <Compile Include="Views\ContentViews.fs" />
    <Compile Include="Views\CollectionViews.fs" />
